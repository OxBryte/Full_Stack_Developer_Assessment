@{
    ViewData["Title"] = "Crypto Dashboard";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@@400;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-color: #0f172a;
            --card-bg: #1e293b;
            --text-primary: #f8fafc;
            --text-secondary: #94a3b8;
            --accent: #38bdf8;
            --success: #22c55e;
            --danger: #ef4444;
            --border: #334155;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-primary);
            font-family: 'Inter', system-ui, sans-serif;
            margin: 0;
            padding: 2rem;
            min-height: 100vh;
        }

        .dashboard-container {
            max-width: 1200px;
            margin: 0 auto;
        }

        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 3rem;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .brand h1 {
            font-size: 2.5rem;
            font-weight: 800;
            margin: 0;
            background: linear-gradient(to right, #38bdf8, #818cf8);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .actions {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .btn {
            background: var(--accent);
            color: white;
            border: none;
            padding: 0.75rem 1.5rem;
            border-radius: 0.5rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            box-shadow: 0 4px 6px -1px rgba(56, 189, 248, 0.2);
        }

        .btn:hover:not(:disabled) {
            opacity: 0.9;
            transform: translateY(-1px);
            box-shadow: 0 10px 15px -3px rgba(56, 189, 248, 0.3);
        }

        .btn:disabled {
            background: var(--text-secondary);
            cursor: not-allowed;
            box-shadow: none;
        }

        .status-badge {
            font-size: 0.875rem;
            font-weight: 600;
            padding: 0.5rem 1rem;
            border-radius: 2rem;
            transition: all 0.3s;
            opacity: 0;
        }

        .status-badge.show { opacity: 1; }
        .status-badge.success { background: rgba(34, 197, 94, 0.1); color: var(--success); }
        .status-badge.error { background: rgba(239, 68, 68, 0.1); color: var(--danger); }

        .crypto-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 1.5rem;
        }

        .crypto-card {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 1rem;
            padding: 1.5rem;
            transition: all 0.3s ease;
            display: flex;
            flex-direction: column;
            gap: 1rem;
            position: relative;
            overflow: hidden;
        }

        .crypto-card::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(to right, transparent, var(--accent), transparent);
            transform: translateX(-100%);
            transition: transform 0.5s;
        }

        .crypto-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.3);
            border-color: var(--accent);
        }

        .crypto-card:hover::after {
            transform: translateX(100%);
        }

        .card-header {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .coin-icon {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            background: var(--bg-color);
            padding: 2px;
        }

        .coin-info h2 {
            margin: 0;
            font-size: 1.25rem;
            font-weight: 700;
        }

        .coin-info .symbol {
            color: var(--text-secondary);
            text-transform: uppercase;
            font-size: 0.875rem;
            font-weight: 600;
        }

        .card-body {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            margin-top: 0.5rem;
        }

        .price-container {
            display: flex;
            flex-direction: column;
        }

        .price-label {
            font-size: 0.75rem;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .price-value {
            font-size: 1.75rem;
            font-weight: 800;
            color: var(--text-primary);
        }

        .trend {
            padding: 0.375rem 0.75rem;
            border-radius: 0.5rem;
            font-size: 0.875rem;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 0.25rem;
        }

        .trend.up { color: var(--success); background: rgba(34, 197, 94, 0.1); }
        .trend.down { color: var(--danger); background: rgba(239, 68, 68, 0.1); }
        .trend.stable { color: var(--text-secondary); background: rgba(148, 163, 184, 0.1); }

        .card-footer {
            border-top: 1px solid var(--border);
            padding-top: 1rem;
            font-size: 0.75rem;
            color: var(--text-secondary);
            display: flex;
            justify-content: space-between;
        }

        .loader {
            width: 18px;
            height: 18px;
            border: 3px solid rgba(255,255,255,0.3);
            border-radius: 50%;
            border-top-color: #fff;
            animation: spin 0.8s linear infinite;
        }

        @@keyframes spin {
            to { transform: rotate(360deg); }
        }

        .hidden { display: none; }

        #emptyState {
            text-align: center;
            padding: 4rem;
            color: var(--text-secondary);
            grid-column: 1 / -1;
        }
    </style>
</head>
<body>
    <div class="dashboard-container">
        <header>
            <div class="brand">
                <h1>💎 Crypto Tracker</h1>
            </div>
            <div class="actions">
                <div id="statusMessage" class="status-badge"></div>
                <button id="updateBtn" class="btn">
                    <span id="btnText">Update Prices</span>
                    <div id="btnLoader" class="loader hidden"></div>
                </button>
            </div>
        </header>

        <main id="cryptoGrid" class="crypto-grid">
            <div id="emptyState">Loading assets...</div>
        </main>
    </div>

    <script>
        const updateBtn = document.getElementById("updateBtn");
        const btnText = document.getElementById("btnText");
        const btnLoader = document.getElementById("btnLoader");
        const statusMessage = document.getElementById("statusMessage");
        const cryptoGrid = document.getElementById("cryptoGrid");

        function formatTime(dateStr) {
            if (!dateStr) return 'Never';
            const date = new Date(dateStr);
            return date.toLocaleString(undefined, {
                month: 'short',
                day: 'numeric',
                hour: '2-digit',
                minute: '2-digit'
            });
        }

        function renderGrid(coins) {
            if (!coins || coins.length === 0) {
                cryptoGrid.innerHTML = '<div id="emptyState">No assets found. Click update to fetch data.</div>';
                return;
            }

            cryptoGrid.innerHTML = coins.map(coin => {
                const trendIcon = coin.trendIndicator === 'up' ? '↗️' : (coin.trendIndicator === 'down' ? '↘️' : '➖');
                const trendClass = coin.trendIndicator;
                const trendValue = coin.trendPercentage ? Math.abs(coin.trendPercentage).toFixed(2) + '%' : '';

                return `
                    <div class="crypto-card">
                        <div class="card-header">
                            <img src="${coin.iconUrl || 'https://static.coingecko.com/s/missing_thumb_2x-90c79e61678839841804f5e7149a464506c8b98b0f7e6f30a90ca643e997a488.png'}" 
                                 alt="${coin.name}" class="coin-icon" onerror="this.src='https://via.placeholder.com/48?text=${coin.symbol}'">
                            <div class="coin-info">
                                <h2>${coin.name}</h2>
                                <span class="symbol">${coin.symbol}</span>
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="price-container">
                                <span class="price-label">Current Price</span>
                                <div class="price-value">$${coin.currentPrice.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 6 })}</div>
                            </div>
                            <div class="trend ${trendClass}">
                                <span>${trendIcon}</span>
                                <span>${trendValue}</span>
                            </div>
                        </div>
                        <div class="card-footer">
                            <span>Last Sync</span>
                            <span>${formatTime(coin.lastUpdated)}</span>
                        </div>
                    </div>
                `;
            }).join('');
        }

        async function fetchLatest() {
            try {
                const response = await fetch("/api/crypto/latest-prices");
                if (response.ok) {
                    const data = await response.json();
                    renderGrid(data);
                }
            } catch (error) {
                console.error("Fetch error:", error);
            }
        }

        function showStatus(text, type) {
            statusMessage.innerText = text;
            statusMessage.className = `status-badge show ${type}`;
            setTimeout(() => {
                statusMessage.classList.remove('show');
            }, 3000);
        }

        updateBtn.addEventListener("click", async () => {
            updateBtn.disabled = true;
            btnText.innerText = "Syncing...";
            btnLoader.classList.remove("hidden");

            try {
                const response = await fetch("/api/crypto/update-prices", { method: "POST" });
                if (response.ok) {
                    showStatus("✅ Prices Synced", "success");
                    await fetchLatest();
                } else {
                    const err = await response.json();
                    showStatus("❌ " + (err.message || "Sync Failed"), "error");
                }
            } catch (error) {
                showStatus("❌ Connection Error", "error");
            } finally {
                updateBtn.disabled = false;
                btnText.innerText = "Update Prices";
                btnLoader.classList.add("hidden");
            }
        });

        // Auto-refresh every minute
        setInterval(fetchLatest, 60000);
        fetchLatest();
    </script>
</body>
</html>